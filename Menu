    let isBilingual = true;

    // Toggle between Bilingual and Vietnamese only
    function toggleLang() {
      isBilingual = !isBilingual;
      renderUI();
    }

    // Render the entire DOM based on the selected language state
    function renderUI() {
      const heroBtn = document.getElementById('hero-btn');
      const heroDesc = document.getElementById('hero-desc');
      const heroSub = document.getElementById('hero-sub');

      if (isBilingual) {
        heroSub.innerText = 'HANOI • EST 2004';
        heroDesc.innerHTML = 'The meeting place of smiles.<br><span class="text-sm not-italic opacity-80 font-light italic">Điểm hẹn của những nụ cười.</span>';
        heroBtn.innerText = 'VIEW MENU';
      } else {
        heroSub.innerText = 'HÀ NỘI • SINCE 2004';
        heroDesc.innerText = 'Điểm hẹn của những nụ cười.';
        heroBtn.innerText = 'XEM THỰC ĐƠN';
      }

      // Render Navigation
      const navContainer = document.getElementById('quick-nav');
      navContainer.innerHTML = menuData.map((sec, idx) => `
        <a href="#${sec.id}" class="nav-pill px-5 py-2 rounded-full border border-[#d4b99f] text-sm ${idx === 0 ? 'active' : ''}">
          ${isBilingual ? `${sec.title_en} <span class="text-[10px] opacity-60">(${sec.title_vi})</span>` : sec.title_vi}
        </a>
      `).join('');

      // Render Menu Items
      const menuRoot = document.getElementById('menu-root');
      menuRoot.innerHTML = menuData.map(sec => `
        <section id="${sec.id}" class="mb-16 scroll-mt-24 section-group">
          <h3 class="text-2xl font-semibold mb-8 flex items-center gap-3 uppercase tracking-wide">
            <span class="w-8 h-[2px] bg-[#d97706]"></span>
            ${sec.icon} ${isBilingual ? `${sec.title_en} <span class="text-sm font-light text-gray-400 italic">/ ${sec.title_vi}</span>` : sec.title_vi}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            ${sec.items.map(item => `
              <div class="menu-card bg-white p-5 rounded-2xl flex justify-between items-center shadow-sm">
                <div class="flex flex-col pr-2">
                    <span class="font-medium text-gray-800 leading-tight">
                        ${isBilingual ? item.en : item.vi}
                    </span>
                    ${isBilingual ? `<span class="text-[11px] text-[#d97706] italic font-light mt-0.5 leading-tight">${item.vi}</span>` : ''}
                </div>
                <span class="text-[#d97706] font-bold text-lg whitespace-nowrap">${item.price}</span>
              </div>
            `).join('')}
          </div>
        </section>
      `).join('');

      // Render Footer info
      const footerInfo = document.getElementById('footer-info');
      footerInfo.innerHTML = `
          <p>📍 ${isBilingual ? 'Hanoi (Hà Nội)' : 'Hà Nội'}</p>
          <p>⏰ ${isBilingual ? '07:00 AM - 11:00 PM (07:00 - 23:00)' : '07:00 - 23:00'}</p>
          <p>📞 Hotline: 0933 556 650</p>
      `;

      // Re-initialize ScrollSpy after rendering
      initScrollSpy();
    }

    // ScrollSpy Logic for Sticky Navigation
    function initScrollSpy() {
      const pills = document.querySelectorAll('.nav-pill');
      const sections = document.querySelectorAll('.section-group');
      
      window.addEventListener('scroll', () => {
        let current = "";
        sections.forEach(section => {
          if (window.scrollY >= (section.offsetTop - 180)) {
            current = section.getAttribute('id');
          }
        });
        
        pills.forEach(pill => {
          pill.classList.remove('active');
          if (pill.getAttribute('href') === `#${current}`) {
            pill.classList.add('active');
            // Scroll the active pill into view horizontally
            pill.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
          }
        });
      });
    }

    // Initial render call on page load
    renderUI();
